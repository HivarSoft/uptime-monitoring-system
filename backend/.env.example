# ─── Server ───────────────────────────────────────────────────────────────────
PORT=911

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Atlas:  mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/uptime?retryWrites=true&w=majority
# Local:  mongodb://127.0.0.1:27017/uptime
MongoDBURL=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/uptime?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# ─── Redis (required for BullMQ queue) ───────────────────────────────────────
# Local:   redis://127.0.0.1:6379
# Upstash: rediss://:password@your-endpoint.upstash.io:6380
# If Redis is unavailable, checks run directly in the scheduler (no queue).
REDIS_URL=redis://127.0.0.1:6379

# ─── BullMQ worker concurrency ────────────────────────────────────────────────
# Number of parallel check jobs per worker process (default: 50)
# Scale: 50 workers × 200ms avg check ≈ 250 checks/sec per process
WORKER_CONCURRENCY=50

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Deployed frontend URL — leave blank for local dev
FRONTEND_URL=

# ─── Quick-start (local) ──────────────────────────────────────────────────────
# 1. Start Redis: docker run -p 6379:6379 redis:7-alpine
# 2. cp backend/.env.example backend/.env  — fill MongoDBURL + JWT_SECRET
# 3. cd backend && npm install && npm run dev
# 4. cd frontend && npm install && npm run dev  → http://localhost:5173
