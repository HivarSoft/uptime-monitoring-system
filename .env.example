# Root-level env reference — actual values go in backend/.env and frontend/.env
# See backend/.env.example and frontend/.env.example for full variable lists.

# Quick-start local setup:
#   1. cp backend/.env.example  backend/.env   — fill in MongoDBURL + JWT_SECRET
#   2. cp frontend/.env.example frontend/.env  — adjust VITE_BASE_URL if needed
#   3. cd backend  && npm install && npm run dev
#   4. cd frontend && npm install && npm run dev
